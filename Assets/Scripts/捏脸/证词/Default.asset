  organStatementGroups:
  - partId: hairstyle
    spriteStatements:
    - statements:
      - "ta\u7684\u5934\u53D1\u8F6E\u5ED3\u5F88\u788E\uFF0C\u6CA1\u6709\u5218\u6D77\uFF0C\u989D\u5934\u4E0A\u5F88\u5149\u6D01\u3002"
      - "ta\u7684\u5934\u53D1\u7B80\u76F4\u5C31\u662F\u827E\u4F26\u8036\u683C\u5C14\uFF01\u4EC0\u4E48\uFF0C\u4F60\u4E0D\u4F1A\u4E0D\u77E5\u9053\u5427\uFF1F"
      - "\u90A3\u4E2A\u4EBA\u7684\u5934\u53D1\u4E71\u84EC\u84EC\u7684\uFF0C\u50CF\u4E00\u56E2\u9ED1\u8272\u7684\u6742\u8349\uFF0C\u770B\u5230\u5C31\u60F3\u7ED9\u4ED6\u5243\u4E86\u3002"
    - statements:
      - "\u53D1\u578B\u5F88\u6574\uFF0C\u662F\u987A\u4E0B\u6765\u76D6\u7740\u7684\uFF0C\u6574\u4F53\u7279\u522B\u50CF\u5B66\u751F\u5934\uFF0C\u8F6E\u5ED3\u5706\u5706\u7684\u3002"
      - "\u5934\u53D1\u5F88\u50CF\u73A9\u539F\u795E\u7684\u53EF\u4EE5\u8BF4\u5417...\uFF08ky\u81F4\u6B49\u5730\u56FE\u70AE\u81F4\u6B49\u523B\u677F\u5370\u8C61\u81F4\u6B49\uFF09"
      - "\u5934\u53D1\u670D\u670D\u5E16\u5E16\u7684\uFF0C\u8138\u4E5F\u5F88\u5706\uFF0C\u4E00\u80A1\u8001\u5B9E\u61A8\u539A\u7684\u6C14\u8D28\u3002"
    - statements:
      - "\u5934\u53D1\u662F\u987A\u7740\u5782\u4E0B\u6765\u7684\uFF0C\u8D70\u5411\u6BD4\u8F83\u81EA\u7136\uFF0C\u524D\u9762\u7684\u788E\u53D1\u628A\u8138\u4FEE\u5F97\u5F88\u67D4\uFF0C\u6574\u4F53\u6709\u70B9\u6587\u6C14\u3002"
      - "\u662F\u4E2A\u957F\u5934\u53D1\u7684\u5973\u751F\uFF1F\u5934\u53D1\u662F\u81EA\u7136\u62AB\u7740\u7684\u3002"
      - "\u6211\u5C31\u8BB0\u5F97\u8111\u95E8\u4E2D\u592E\u6709\u597D\u660E\u663E\u7684\u4E00\u7F15\u5934\u53D1\uFF0C\u5176\u4ED6\u4E0D\u8BB0\u5F97\u4E86\uFF0C\u6BCF\u5929\u8FD9\u4E48\u5FD9\u54EA\u6709\u65F6\u95F4\u5173\u5FC3\u522B\u4EBA\u54DF\uFF01"
    - statements:
      - "\u5934\u53D1\u6253\u7406\u5F97\u5F88\u6B63\u5F0F\uFF0C\u50CF\u8001\u7535\u5F71\u91CC\u7684\u7EC5\u58EB\u53D1\u578B\uFF0C\u6574\u4E2A\u4EBA\u770B\u7740\u5F88\u7CBE\u81F4\u3002"
      - "\u53D1\u578B\u5F88\u82F1\u4F26\uFF0C\u68B3\u5F97\u7279\u522B\u6574\uFF0C\u6CB9\u4EAE\u6CB9\u4EAE\u7684\uFF0C\u4E00\u770B\u5C31\u662F\u5F88\u8BB2\u7A76\u7684\u90A3\u79CD\u3002"
    - statements:
      - "Ta\u7684\u53D1\u578B\u5F88\u7F8E\uFF0C\u662F\u6B27\u6D32\u7EDD\u4E16\u7F8E\u4EBA\u90A3\u6837\u7684\u7F8E\u3002"
      - "\u4E4C\u9ED1\u4EAE\u4E3D\u7684\u957F\u53D1\uFF0C\u670D\u670D\u5E16\u5E16\u5730\u76D8\u597D\u3002"
    - statements:
      - "\u989D\uFF0CTa\u7684\u5934\u53D1\uFF0C\u8BA9\u6211\u5FCD\u4E0D\u4F4F\u60F3\u8D77\u67D0\u4F4D\u7F8E\u56FD\u7684\u603B\u7EDF..."
      - "Ta\u662F\u91D1\u8272\u7684\u5934\u53D1\uFF0C\u5E94\u8BE5\u633A\u72EC\u7279\u7684\u3002"
    - statements:
      - "\u53D1\u9645\u7EBF\u5F88\u9AD8\uFF0C\u4F46\u662F\u5934\u53D1\u68B3\u7684\u5F88\u6574\u9F50\u3002"
      - "\u5F88\u6807\u51C6\u7684\u5E72\u90E8\u53D1\u578B\uFF01"
    - statements:
      - "Ta\u6234\u4E86\u5E3D\u5B50\uFF01"
      - "Ta\u6709\u4E00\u9876\u5F88\u4F18\u96C5\u7684\u793C\u5E3D\uFF01"
  - partId: eyestylel
    spriteStatements:
    - statements:
      - "\u5DE6\u773C\u770B\u4EBA\u7684\u65F6\u5019\u51B7\u51B7\u7684\uFF0C\u773C\u775B\u8F6E\u5ED3\u7279\u522B\u91CD\uFF0C\u77B3\u5B54\u7279\u522B\u6E05\u695A\uFF0C\u76EF\u7740\u4EBA\u5F88\u4E0D\u8212\u670D\u3002"
      - "\u5DE6\u773C\u50CF\u9ED1\u9ED1\u7684\u5C0F\u6D1E\uFF0C\u91CC\u9762\u6709\u4EAE\u4EAE\u7684\u70B9\uFF0C\u770B\u8D77\u6765\u50CF\u4E00\u76F4\u5728\u770B\u6211\u3002"
      - "\u5DE6\u773C\u538B\u8FEB\u611F\u5F88\u5F3A\uFF0C\u6709\u4E00\u4E2A\u5F88\u5706\u7684\u77B3\u5B54\uFF0C\u597D\u51F6\u7684\u6837\u5B50\u3002"
    - statements:
      - "\u5DE6\u773C\u4E00\u76F4\u50CF\u772F\u7740\uFF0C\u5F2F\u5F2F\u7684\uFF0C\u6709\u70B9\u7B11\u610F\uFF0C\u4F46\u53C8\u8BA9\u4EBA\u89C9\u5F97\u4E0D\u592A\u597D\u63A5\u8FD1\u3002"
      - "\u5DE6\u773C\u50CF\u5728\u5077\u5077\u7B11\uFF0C\u4E0D\u662F\u5706\u5706\u7684\u90A3\u79CD\uFF0C\u770B\u8D77\u6765\u5F2F\u5F2F\u7684\u3002"
      - "\u6211\u600E\u4E48\u611F\u89C9\u90A3\u4E2A\u5DE6\u773C\u4E00\u76F4\u6CA1\u7741\u5F00..."
    - statements:
      - "\u5DE6\u773C\u4E0B\u773C\u7751\u5F88\u660E\u663E\uFF0C\u662F\u5F88\u660E\u663E\u7684\u51E4\u773C\uFF01"
      - "\u611F\u89C9\u773C\u795E\u597D\u5E7D\u6028...\u5DE6\u8FB9\u4E0B\u773C\u7751\u597D\u660E\u663E"
    - statements:
      - "\u5DE6\u773C\u7279\u522B\u6709\u795E\uFF0C\u770B\u8FC7\u6765\u7684\u65F6\u5019\u611F\u89C9\u6574\u4E2A\u4EBA\u4E00\u4E0B\u5B50\u7CBE\u795E\u8D77\u6765\u4E86\uFF01"
      - "\u5DE6\u773C\u70AF\u70AF\u6709\u795E\uFF01"
      - "\u5DE6\u773C\u5F88\u660E\u4EAE\uFF0C\u5F88\u7075\u52A8\uFF01"
    - statements:
      - "\u611F\u89C9\u5DE6\u773C\u9ED1\u773C\u5708\u5F88\u91CD\u6B38\u3002\u3002\u3002Ta\u4E5F\u8981\u4E0A\u5B66\u5417\uFF1F"
      - "\u6F06\u9ED1\u7684\u5DE6\u773C\uFF0C\u773C\u73E0\u91CC\u4E00\u70B9\u9AD8\u5149\u4E5F\u6CA1\u6709"
    - statements:
      - "\u554A\uFF0C\u8FD9\u4E2A\u5DE6\u773C\uFF0C\uFF0C\u7279\u522B\u50CF\u67D0\u4F4D\u7F8E\u56FD\u603B\u7EDF\u7684\u5DE6\u773C"
      - "\u5DE6\u773C\u7684\u4E0A\u773C\u7751\u6709\u5F88\u591A\u76B1\u7EB9..."
    - statements:
      - "\u5DE6\u773C\u7741\u5F97\u5F88\u5706\uFF0C\u773C\u73E0\u4E5F\u5F88\u5706\uFF01"
      - "\u5DE6\u773C\u5706\u5F97\u79BB\u8C31\uFF0C\u9ED1\u773C\u73E0\u5728\u4E2D\u95F4\u5F88\u660E\u663E\u3002"
    - statements:
      - "\u8FD9\u4E2A\u5DE6\u773C\u5F88\u5706\uFF0C\u773C\u776B\u6BDB\u5F88\u957F\uFF0C\u77B3\u4EC1\u4E5F\u5F88\u6E05\u6670\u3002"
      - "\u5DE6\u773C\u5706\u7741\uFF0C\u77B3\u5B54\u5B8C\u6574\u6E05\u695A\uFF0C\u773C\u795E\u76F4\u76F4\u9876\u51FA\u6765\uFF0C\u6709\u70B9\u88AB\u5413\u4F4F\u7684\u611F\u89C9\u3002"
  - partId: eyestyler
    spriteStatements:
    - statements:
      - "\u53F3\u773C\u770B\u4EBA\u7684\u65F6\u5019\u51B7\u51B7\u7684\uFF0C\u773C\u775B\u8F6E\u5ED3\u7279\u522B\u91CD\uFF0C\u77B3\u5B54\u7279\u522B\u6E05\u695A\uFF0C\u76EF\u7740\u4EBA\u5F88\u4E0D\u8212\u670D\u3002"
      - "\u53F3\u773C\u50CF\u9ED1\u9ED1\u7684\u5C0F\u6D1E\uFF0C\u91CC\u9762\u6709\u4EAE\u4EAE\u7684\u70B9\uFF0C\u770B\u8D77\u6765\u50CF\u4E00\u76F4\u5728\u770B\u6211\u3002"
      - "\u53F3\u773C\u538B\u8FEB\u611F\u5F88\u5F3A\uFF0C\u6709\u4E00\u4E2A\u5F88\u5706\u7684\u77B3\u5B54\uFF0C\u597D\u51F6\u7684\u6837\u5B50"
    - statements:
      - "\u53F3\u773C\u4E00\u76F4\u50CF\u772F\u7740\uFF0C\u5F2F\u5F2F\u7684\uFF0C\u6709\u70B9\u7B11\u610F\uFF0C\u4F46\u53C8\u8BA9\u4EBA\u89C9\u5F97\u4E0D\u592A\u597D\u63A5\u8FD1\u3002"
      - "\u53F3\u773C\u50CF\u5728\u5077\u5077\u7B11\uFF0C\u4E0D\u662F\u5706\u5706\u7684\u90A3\u79CD\uFF0C\u770B\u8D77\u6765\u5F2F\u5F2F\u7684\u3002"
      - "\u6211\u600E\u4E48\u611F\u89C9\u90A3\u4E2A\u53F3\u773C\u4E00\u76F4\u6CA1\u7741\u5F00..."
    - statements:
      - "\u53F3\u773C\u4E0B\u773C\u7751\u5F88\u660E\u663E\uFF0C\u662F\u5F88\u660E\u663E\u7684\u51E4\u773C\uFF01"
      - "\u611F\u89C9\u773C\u795E\u597D\u5E7D\u6028...\u53F3\u8FB9\u4E0B\u773C\u7751\u597D\u660E\u663E\u3002"
    - statements:
      - "\u53F3\u773C\u7279\u522B\u6709\u795E\uFF0C\u770B\u8FC7\u6765\u7684\u65F6\u5019\u611F\u89C9\u6574\u4E2A\u4EBA\u4E00\u4E0B\u5B50\u7CBE\u795E\u8D77\u6765\u4E86\uFF01"
      - "\u53F3\u773C\u70AF\u70AF\u6709\u795E\uFF01"
      - "\u53F3\u773C\u5F88\u660E\u4EAE\uFF0C\u5F88\u7075\u52A8\uFF01"
    - statements:
      - "\u611F\u89C9\u53F3\u773C\u9ED1\u773C\u5708\u5F88\u91CD\u6B38\u3002\u3002\u3002Ta\u4E5F\u8981\u4E0A\u5B66\u5417\uFF1F"
      - "\u6F06\u9ED1\u7684\u53F3\u773C\uFF0C\u773C\u73E0\u91CC\u4E00\u70B9\u9AD8\u5149\u4E5F\u6CA1\u6709"
    - statements:
      - "\u554A\uFF0C\u8FD9\u4E2A\u53F3\u773C\uFF0C\uFF0C\u7279\u522B\u50CF\u67D0\u4F4D\u7F8E\u56FD\u603B\u7EDF\u7684\u5DE6\u773C"
      - "\u53F3\u773C\u7684\u4E0A\u773C\u7751\u6709\u5F88\u591A\u76B1\u7EB9..."
    - statements:
      - "\u53F3\u773C\u7741\u5F97\u5F88\u5706\uFF0C\u773C\u73E0\u4E5F\u5F88\u5706\uFF01"
      - "\u53F3\u773C\u5706\u5F97\u79BB\u8C31\uFF0C\u9ED1\u773C\u73E0\u5728\u4E2D\u95F4\u5F88\u660E\u663E\u3002"
    - statements:
      - "\u8FD9\u4E2A\u53F3\u773C\u5F88\u5706\uFF0C\u773C\u776B\u6BDB\u5F88\u957F\uFF0C\u77B3\u4EC1\u4E5F\u5F88\u6E05\u6670\u3002"
      - "\u53F3\u773C\u5706\u7741\uFF0C\u77B3\u5B54\u5B8C\u6574\u6E05\u695A\uFF0C\u773C\u795E\u76F4\u76F4\u9876\u51FA\u6765\uFF0C\u6709\u70B9\u88AB\u5413\u4F4F\u7684\u611F\u89C9\u3002"
  - partId: eyebrowstylel
    spriteStatements:
    - statements:
      - "\u5DE6\u8FB9\u7684\u7709\u6BDB\u8F6E\u5ED3\u597D\u6E05\u6670\u7684\u54DF\uFF0C\u7531\u7C97\u53D8\u7EC6\u7684\u3002"
      - "\u5DE6\u8FB9\u7684\u7709\u6BDB\u597D\u51F6\u7684\u6837\u5B50\uFF0C\u7709\u6BDB\u786C\u786C\u7684\u3002\u4ECE\u5DE6\u4E0A\u5F80\u53F3\u4E0B\u6487\u7684\u3002"
      - "\u6211\u8BB0\u5F97\u5DE6\u7709\u6BDB\uFF0C\u597D\u663E\u773C\u7684\u5012\u516B\u5B57\u7709\u54E6\u3002 "
    - statements:
      - "\u4ED6\u7684\u5DE6\u7709\u6BDB\u5F88\u987A\uFF0C\u5F2F\u5F97\u5F88\u81EA\u7136\uFF0C\u611F\u89C9\u6BD4\u4E00\u822C\u4EBA\u66F4\u67D4\u4E00\u70B9\u3002"
      - "\u5DE6\u7709\u6BDB\u5F27\u5EA6\u662F\u6536\u7740\u7684\uFF0C\u4E0D\u51B2\uFF0C\u5E26\u4E00\u70B9\u6587\u6C14\u3002"
      - "\u6211\u8BB0\u5F97\u5DE6\u7709\u662F\u987A\u7740\u5F2F\u8FC7\u53BB\u7684\uFF0C\u7709\u6BDB\u7A00\u7A00\u62C9\u62C9\u7684\u3002"
    - statements:
      - "\u5DE6\u8FB9\u7709\u6BDB\u50CF\u4E00\u76F4\u76B1\u7740\uFF0C\u6709\u79CD\u4E0D\u8010\u70E6\u7684\u52B2\u513F\uFF0C\u50CF\u968F\u65F6\u8981\u53D1\u706B\u3002"
      - "\u5DE6\u8FB9\u7709\u6BDB\u7279\u522B\u62E7\u5DF4\uFF0C\u50CF\u8001\u662F\u5728\u618B\u7740\u706B\uFF0C\u4E0D\u77E5\u9053\u88AB\u8C01\u60F9\u4E86\u3002"
    - statements:
      - "\u5DE6\u8FB9\u7709\u6BDB\u633A\u653E\u677E\u7684\uFF0C\u50CF\u4E2A\u5C16\u62EC\u53F7\uFF01"
      - "\u5DE6\u8FB9\u7709\u6BDB\u5F88\u8212\u5C55\uFF0C\u6CA1\u4EC0\u4E48\u950B\u8292\uFF0C\u6574\u4F53\u5F88\u89C4\u77E9\uFF0C\u50CF\u90A3\u79CD\u4E0D\u592A\u4F1A\u53D1\u706B\u7684\u4EBA\u3002"
      - "\u5DE6\u8FB9\u7684\u7709\u6BDB\u50CF\u4E2A\u6A2A\u6298..."
    - statements:
      - "\u554A\uFF0C \u8FD9\u4E2A\u4EBA\uFF0C\u8BF4\u8D77\u6765\u90FD\u5BB3\u6015\uFF0CTa\u6CA1\u6709\u5DE6\u8FB9\u7684\u7709\u6BDB\uFF01"
    - statements:
      - "Ta\u7684\u5DE6\u7709\u6BDB\u4E0A\u9762\u6709\u4E00\u5708\u4E00\u5708\u7684\u76B1\u7EB9\uFF01"
      - "Ta\u7684\u5DE6\u7709\u6BDB\uFF0C\u53C8\u7EC6\u53C8\u9AD8\uFF0C\u800C\u4E14\u662F\u6311\u8D77\u6765\u7684\uFF0C\u4E0A\u9762\u8FD8\u6709\u597D\u51E0\u5708\u76B1\u7EB9
        \u3002"
    - statements:
      - "\u5DE6\u7709\u662F\u4E00\u6574\u9053\u539A\u5F27\uFF0C\u5706\u5706\u62F1\u8D77\u6765\u3002"
      - "\u5DE6\u7709\u6BDB\u662F\u4E00\u4E2A\u5F88\u6E05\u6670\u7684\u6708\u7259\u5F62\u3002"
  - partId: eyebrowstyler
    spriteStatements:
    - statements:
      - "\u53F3\u8FB9\u7684\u7709\u6BDB\u8F6E\u5ED3\u597D\u6E05\u6670\u7684\u54DF\uFF0C\u7531\u7C97\u53D8\u7EC6\u7684\u3002"
      - "\u53F3\u8FB9\u7684\u7709\u6BDB\u597D\u51F6\u7684\u6837\u5B50\uFF0C\u7709\u6BDB\u786C\u786C\u7684\u3002\u4ECE\u5DE6\u4E0A\u5F80\u53F3\u4E0B\u6487\u7684\u3002"
      - "\u6211\u8BB0\u5F97\u53F3\u7709\u6BDB\uFF0C\u597D\u663E\u773C\u7684\u5012\u516B\u5B57\u7709\u54E6\u3002 "
    - statements:
      - "\u4ED6\u7684\u53F3\u7709\u6BDB\u5F88\u987A\uFF0C\u5F2F\u5F97\u5F88\u81EA\u7136\uFF0C\u611F\u89C9\u6BD4\u4E00\u822C\u4EBA\u66F4\u67D4\u4E00\u70B9\u3002"
      - "\u53F3\u7709\u6BDB\u5F27\u5EA6\u662F\u6536\u7740\u7684\uFF0C\u4E0D\u51B2\uFF0C\u5E26\u4E00\u70B9\u6587\u6C14\u3002"
      - "\u6211\u8BB0\u5F97\u53F3\u7709\u662F\u987A\u7740\u5F2F\u8FC7\u53BB\u7684\uFF0C\u7709\u6BDB\u7A00\u7A00\u62C9\u62C9\u7684\u3002"
    - statements:
      - "\u53F3\u8FB9\u7709\u6BDB\u50CF\u4E00\u76F4\u76B1\u7740\uFF0C\u6709\u79CD\u4E0D\u8010\u70E6\u7684\u52B2\u513F\uFF0C\u50CF\u968F\u65F6\u8981\u53D1\u706B\u3002"
      - "\u53F3\u8FB9\u7709\u6BDB\u7279\u522B\u62E7\u5DF4\uFF0C\u50CF\u8001\u662F\u5728\u618B\u7740\u706B\uFF0C\u4E0D\u77E5\u9053\u88AB\u8C01\u60F9\u4E86\u3002"
    - statements:
      - "\u53F3\u8FB9\u7709\u6BDB\u633A\u653E\u677E\u7684\uFF0C\u50CF\u4E2A\u5C16\u62EC\u53F7\uFF01"
      - "\u53F3\u8FB9\u7709\u6BDB\u5F88\u8212\u5C55\uFF0C\u6CA1\u4EC0\u4E48\u950B\u8292\uFF0C\u6574\u4F53\u5F88\u89C4\u77E9\uFF0C\u50CF\u90A3\u79CD\u4E0D\u592A\u4F1A\u53D1\u706B\u7684\u4EBA\u3002"
      - "\u53F3\u8FB9\u7684\u7709\u6BDB\u50CF\u4E2A\u6A2A\u6298..."
    - statements:
      - "\u554A\uFF0C \u8FD9\u4E2A\u4EBA\uFF0C\u8BF4\u8D77\u6765\u90FD\u5BB3\u6015\uFF0CTa\u6CA1\u6709\u53F3\u8FB9\u7684\u7709\u6BDB\uFF01"
    - statements:
      - "Ta\u7684\u53F3\u7709\u6BDB\u4E0A\u9762\u6709\u4E00\u5708\u4E00\u5708\u7684\u76B1\u7EB9\uFF01"
      - "Ta\u7684\u53F3\u7709\u6BDB\uFF0C\u53C8\u7EC6\u53C8\u9AD8\uFF0C\u800C\u4E14\u662F\u6311\u8D77\u6765\u7684\uFF0C\u4E0A\u9762\u8FD8\u6709\u597D\u51E0\u5708\u76B1\u7EB9
        \u3002"
    - statements:
      - "\u53F3\u7709\u662F\u4E00\u6574\u9053\u539A\u5F27\uFF0C\u5706\u5706\u62F1\u8D77\u6765\u3002"
      - "\u53F3\u7709\u6BDB\u662F\u4E00\u4E2A\u5F88\u6E05\u6670\u7684\u6708\u7259\u5F62\u3002"
  - partId: nosestyle
    spriteStatements:
    - statements:
      - "\u90A3\u4E2A\u9F3B\u5B50\u6709\u70B9\u50CF\u5916\u56FD\u4EBA\uFF0C\u5C24\u5176\u662F\u5317\u6B27\u90A3\u8FB9\u7684\u3002"
      - "\u597D\u957F\u7684\u9F3B\u5B50\uFF0C\u53EA\u8BB0\u5F97\u8FD9\u4E2A\u4E86\u3002"
      - "\u989D...\u597D\u5178\u578B\u7684\u9E70\u94A9\u9F3B\u3002\u53EA\u89C1\u8FC7\u4E00\u9762\u5370\u8C61\u4E5F\u5F88\u6DF1\u523B\u5427\u3002"
    - statements:
      - "Ta\u7684\u9F3B\u5B50\u5C5E\u4E8E\u8089\u611F\u6BD4\u8F83\u660E\u663E\u7684\u7C7B\u578B\uFF0C\u9F3B\u5934\u5706\uFF0C\u9F3B\u7FFC\u4E5F\u5F88\u5B9E\uFF0C\u770B\u8D77\u6765\u5F88\u6709\u5B58\u5728\u611F\u3002"
      - "\u6211\u5C31\u8BB0\u4F4F\u90A3\u4E2A\u9F3B\u5B50\u4E86\uFF0C\u633A\u8089\u7684\uFF0C\u5706\u5706\u7684\uFF0C\u50CF\u4E2A\u5706\u67F1\u3002"
      - "\u90A3\u9F3B\u5B50\u611F\u89C9\u810F\u810F\u7684..."
    - statements:
      - "\u9F3B\u5B50\u5C5E\u4E8E\u6BD4\u8F83\u5706\u949D\u7684\u90A3\u79CD\uFF0C\u5176\u4ED6\u7684...\u6709\u70B9\u5FD8\u4E86\u3002"
      - "\u6211\u5C31\u8BB0\u5F97\u90A3\u4E2A\u9F3B\u5B50\uFF0C\u597D\u77ED\uFF0C\u770B\u7740\u5F88\u6709\u8FA8\u8BC6\u5EA6\u3002"
      - "\u77ED\u77ED\u6241\u6241\u7684\u9F3B\u5B50\uFF0C\u8DDF\u730E\u8C79\u90A3\u4E9B\u732B\u79D1\u52A8\u7269\u4E00\u6837\u3002"
    - statements:
      - "\u9F3B\u5B50\u6574\u4F53\u662F\u4E09\u89D2\u5F62\u7684\uFF0C\u4E0D\u8FC7\u662F\u5411\u5DE6\u4E0A\u89D2\u503E\u659C\u7684\uFF0C\u8FB9\u7F18\u6709\u70B9\u6A21\u7CCA\u3002"
      - "\u8FD9\u4E2A\u4EBA\u7684\u9F3B\u5B50\u8F6E\u5ED3\u4E0D\u592A\u6E05\u695A\uFF0C\u4E0D\u8FC7\u8FD8\u662F\u86EE\u7ACB\u4F53\u7684\u3002"
      - "Ta\u7684\u9F3B\u5B50\u50CF\u4E2A\u849C\u4E00\u6837\uFF0C\u4F60\u61C2\u6211\u610F\u601D\u5427\uFF1F"
    - statements:
      - "Ta\u7684\u9F3B\u5B50\u90FD\u53EA\u80FD\u770B\u5230\u53F3\u4E0B\u8FB9\u7F18\u3002\u611F\u89C9\u6241\u6241\u7684..."
      - "\u8FD9\u4E2A\u9F3B\u5B50\u5DE6\u4E0A\u89D2\u90FD\u662F\u7A7A\u767D\u7684\u3002"
    - statements:
      - "\u9F3B\u5B50\u957F\u957F\u7684\u3001\u7A84\u7A84\u7684\uFF0C\u9F3B\u5934\u5706\u5706\u7684\uFF0C\u4EAE\u4EAE\u7684\u3002\uFF01"
      - "\u9F3B\u5B50\u5468\u56F4\u7684\u76B1\u7EB9\u5F88\u660E\u663E\u3002"
    - statements:
      - "\u8FD9\u9F3B\u5B50\u53EF\u592A\u6807\u51C6\u4E86\uFF01"
      - "\u9F3B\u7FFC\u8F6E\u5ED3\u5F88\u6E05\u6670\uFF0C\u6574\u4E2A\u9F3B\u5B50\u51E0\u4E4E\u662F\u4E00\u4E2A\u7B49\u8FB9\u4E09\u89D2\u5F62\u3002"
    - statements:
      - "\u8FD9\u4E2A\u9F3B\u5B50\u9634\u5F71\u597D\u91CD\uFF0C\u6211\u4E00\u5F00\u59CB\u8FD8\u4EE5\u4E3A\u662F\u957F\u957F\u7684\u9F3B\u6BDB\u5462\u3002"
      - "\u9F3B\u5B50\u7626\u9AD8\u7626\u9AD8\u7684\uFF01\u5DE6\u8FB9\u662F\u4EAE\u7684\uFF0C\u9F3B\u5B50\u4E0B\u9762\u6709\u9634\u5F71\uFF01"
  - partId: mouthstyle
    spriteStatements:
    - statements:
      - "\u8BF4\u8BDD\u65F6\u5634\u90E8\u5F88\u514B\u5236\uFF0C\u5507\u5F62\u662F\u5012\u4E09\u89D2\u7684\u3002"
      - "\u611F\u89C9\u5634\u89D2\u6709\u70B9\u4F3C\u7B11\u975E\u7B11\u7684\u4E0A\u626C\u3002\u5634\u5507\u6574\u4F53\u662F\u5012\u4E09\u89D2\u7684\u3002"
    - statements:
      - "\u5634\u5507\u633A\u9971\u6EE1\u7684\uFF0C\u5507\u5F62\u5F88\u660E\u663E\uFF0C\u8FD8\u6709\u70B9\u561F\uFF0C\u5C5E\u4E8E\u4E00\u773C\u80FD\u8BB0\u4F4F\u7684\u90A3\u79CD\u5634\u3002"
      - "\u5634\u5DF4\u597D\u50CF\u6709\u70B9\u5730\u5305\u5929\uFF1F\u4E0B\u5634\u5507\u597D\u660E\u663E\u3002"
      - "\u6211\u8BB0\u5F97\u90A3\u4E2A\u4EBA\u603B\u662F\u9732\u51FA\u4E24\u9897\u95E8\u7259\uFF0C\u4F46\u662F\u4E0D\u662F\u9F85\u7259\u3002"
    - statements:
      - "\u5634\u5DF4\u7ED9\u4EBA\u7684\u611F\u89C9\u6709\u70B9\u51B7\uFF0C\u5507\u5F62\u5012\u662F\u633A\u6E05\u6670\u7684\u3002"
      - "\u5C31...\u5F88\u6B63\u5E38\u7684\u4E00\u5F20\u5634\uFF1F\u8F6E\u5ED3\u5F88\u6E05\u6670\uFF0C\u6CA1\u5565\u7279\u522B\u7684\u3002"
    - statements:
      - "\u6709\u4E2A\u9F85\u7259\u561B\uFF0C\u597D\u8BA4\u5F97\u5F88\u3002"
      - "\u5634\u5DF4\u7ED9\u4EBA\u7684\u5370\u8C61\u4E0D\u592A\u597D\uFF0C\u7259\u6709\u70B9\u5F80\u5916\u9876\uFF0C\u7B11\u4E0D\u7B11\u90FD\u5F88\u660E\u663E\u3002"
      - "Ta\u7684\u5634\u50CF\u5C0F\u5154\u5B50\uFF01\uFF01\u5C31\u662F\u6709\u4E24\u4E2A\u5927\u5927\u7684\u95E8\u7259\uFF01\uFF01"
    - statements:
      - "\u597D\u7F8E\u7684\u5634\u5507\uFF0C\u5507\u5F62\u5F88\u5B8C\u6574\uFF0C\u5E94\u8BE5\u6D82\u4E86\u53E3\u7EA2\uFF01"
      - "Ta\u7684\u5634\u5507\u50CF\u7EDD\u4E16\u7F8E\u4EBA\u4E00\u822C\uFF01"
    - statements:
      - "\u7279\u522B\u7279\u522B\u5E73\u7684\u5634\u3002\u4E0A\u4E0B\u5634\u5507\u90FD\u5F88\u5E73\u3002"
      - "\u5634\u5507\u5F88\u8584\uFF0C\u4E00\u5B57\u5F62\u7684\u3002\u54E6\uFF0C\u6211\u7684\u610F\u601D\u662F\u5634\u5507\u5F88\u5E73\u3002"
    - statements:
      - "\u8FD9\u4E2A\u5634\u7684\u5F27\u5EA6\u7B80\u76F4\u4E0D\u53EF\u601D\u8BAE\uFF01Ta\u7684\u5634\u662F\u5411\u4E0B\u51F8\u51FA\u7684\u5F27\u5F62\uFF01"
      - "Ta\u7684\u53E3\u8F6E\u531D\u808C\u975E\u5E38\u660E\u663E\uFF0C\u4E0B\u5634\u5507\u662F\u62BF\u7740\u7684\uFF01"
    - statements:
      - "\u5634\u5507\u5F88\u6A21\u7CCA\uFF0C\u53EA\u8BB0\u5F97\u662F\u5411\u4E0A\u62BF\u7684\u4E86\uFF0C\u4E0B\u5634\u5507\u5F88\u539A\u3002"
      - "\u5634\u5507\u5E72\u5E72\u7684\uFF0C\u4E0B\u5634\u5507\u662F\u4E0A\u5634\u5507\u76843\u500D\u539A\uFF01"
